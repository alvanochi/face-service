# =============================================================================
# Face Recognition Service — Environment Configuration
# =============================================================================

# --- Application ---
APP_NAME=face-service
APP_ENV=development
DEBUG=true
LOG_LEVEL=info

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+psycopg://faceuser:facepass@db:5432/facedb

# --- Internal API Security ---
# Shared secret between Laravel and this service
API_SECRET_KEY=change-me-to-a-long-random-string

# --- Face Pipeline Settings ---
# Pretrained model: vggface2 | casia-webface
FACE_MODEL_PRETRAINED=vggface2
# Minimum detection confidence (MTCNN)
FACE_DETECT_THRESHOLD=0.95
# Verification match threshold (cosine similarity)
FACE_VERIFY_THRESHOLD=0.75
# Maximum faces allowed for enrollment (reject if more)
FACE_MAX_FACES_ENROLL=1
# Minimum face bounding box size (pixels)
FACE_MIN_FACE_SIZE=80
# Maximum upload image size in bytes (5 MB)
MAX_IMAGE_SIZE=5242880

# --- Image Storage ---
IMAGE_STORAGE_PATH=/app/storage/faces

# --- Recognition Settings ---
RECOGNIZE_TOP_K=5

# --- OpenAPI ---
# Set to false in production to hide Swagger UI
OPENAPI_ENABLED=true
